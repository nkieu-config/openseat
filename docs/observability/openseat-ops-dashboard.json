{
  "uid": "openseat-ops",
  "title": "OpenSeat Ops",
  "tags": ["openseat", "m7", "observability"],
  "schemaVersion": 41,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "prometheus",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Metrics (Mimir)",
        "includeAll": false,
        "current": {}
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "RED — traffic, errors, latency",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (rate(http_server_duration_milliseconds_count[$__rate_interval]))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate (5xx)",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_duration_milliseconds_count[$__rate_interval])), 0.001)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 latency",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(http_server_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": {
        "legend": { "calcs": ["max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Business funnel — holds → paid → checked in",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Holds acquired (won vs conflict)",
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(holds_acquired_total[$__rate_interval]))",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Orders paid (range)",
      "gridPos": { "x": 8, "y": 10, "w": 4, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(orders_paid_total[$__range]))" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Checked in (range)",
      "gridPos": { "x": 12, "y": 10, "w": 4, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(tickets_checked_in_total{result=\"admitted\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Webhook events by outcome",
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(webhook_events_total[$__rate_interval]))",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Drop ops — queue + admissions",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Queue depth by event",
      "gridPos": { "x": 0, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event_id) (gate_queue_depth)",
          "legendFormat": "{{event_id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "legend": { "calcs": ["max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Join vs admit rate",
      "gridPos": { "x": 8, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(gate_joins_total[$__rate_interval]))", "legendFormat": "joins" },
        { "refId": "B", "expr": "sum(rate(gate_admitted_total[$__rate_interval]))", "legendFormat": "admitted" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Admissions verified by result",
      "gridPos": { "x": 16, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(admissions_verified_total[$__rate_interval]))",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ]
}
