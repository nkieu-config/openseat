{
  "name": "@openseat/contracts",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "openapi-typescript openapi.json -o src/api.ts --default-non-nullable false",
    "build": "pnpm generate && tsc -p tsconfig.json",
    "typecheck": "pnpm generate && tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@openseat/config": "workspace:*",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  }
}
