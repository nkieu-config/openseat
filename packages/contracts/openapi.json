  "info": {
    "title": "OpenSeat API",
    "description": "REST API for the OpenSeat ticketing platform",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "ada@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "maxLength": 72
          },
          "displayName": {
            "type": "string",
            "example": "Ada Lovelace"
          }
        },
        "required": [
          "email",
          "password",
          "displayName"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "ada@example.com"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "GoogleLoginDto": {
        "type": "object",
        "properties": {
          "credential": {
            "type": "string",
            "description": "Google Identity Services ID token (JWT)"
          }
        },
        "required": [
          "credential"
        ]
      },
      "AddTeamMemberDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "manager",
              "staff"
            ]
          }
        },
        "required": [
          "email",
          "role"
        ]
      },
      "UpdateTeamMemberDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "manager",
              "staff"
            ]
          }
        },
        "required": [
          "role"
        ]
      },
      "DemoLoginDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "buyer",
              "organizer",
              "staff"
            ]
          }
        },
        "required": [
          "role"
        ]
      },
      "CreateTicketTypeDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "General admission"
          },
          "quantity": {
            "type": "number",
            "minimum": 1,
            "maximum": 100000
          },
          "priceSatang": {
            "type": "number",
            "minimum": 0,
            "maximum": 100000000,
            "description": "Price in satang; 0 = free"
          },
          "maxPerOrder": {
            "type": "number",
            "minimum": 1,
            "maximum": 20,
            "default": 10
          }
        },
        "required": [
          "name",
          "quantity",
          "priceSatang"
        ]
      },
      "CreateEventDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Bangkok Indie Fest"
          },
          "description": {
            "type": "string",
            "default": ""
          },
          "venueName": {
            "type": "string",
            "example": "Voice Space, Bangkok"
          },
          "startsAt": {
            "type": "string",
            "example": "2026-09-01T12:00:00.000Z"
          },
          "endsAt": {
            "type": "string",
            "example": "2026-09-01T16:00:00.000Z"
          },
          "ticketTypes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateTicketTypeDto"
            }
          }
        },
        "required": [
          "title",
          "venueName",
          "startsAt",
          "ticketTypes"
        ]
      },
      "UpdateEventDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "venueName": {
            "type": "string"
          },
          "startsAt": {
            "type": "string"
          },
          "endsAt": {
            "type": "string"
          }
        }
      },
      "UpdateTicketTypeDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "minimum": 1,
            "maximum": 100000
          },
          "maxPerOrder": {
            "type": "number",
            "minimum": 1,
            "maximum": 20
          }
        }
      },
      "CheckinDto": {
        "type": "object",
        "properties": {
          "qrToken": {
            "type": "string",
            "description": "The scanned ticket QR token"
          }
        },
        "required": [
          "qrToken"
        ]
      },
      "AcquireHoldDto": {
        "type": "object",
        "properties": {
          "seatId": {
            "type": "string"
          }
        },
        "required": [
          "seatId"
        ]
      },
      "SeatMapSectionDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Front"
          },
          "rows": {
            "type": "number",
            "minimum": 1,
            "maximum": 26
          },
          "cols": {
            "type": "number",
            "minimum": 1,
            "maximum": 30
          },
          "tierName": {
            "type": "string",
            "example": "Front zone"
          },
          "priceSatang": {
            "type": "number",
            "minimum": 0,
            "maximum": 100000000,
            "description": "Price in satang; 0 = free"
          },
          "x": {
            "type": "number",
            "minimum": 0,
            "maximum": 80,
            "description": "Grid column of the section origin (editor layout)"
          },
          "y": {
            "type": "number",
            "minimum": 0,
            "maximum": 200,
            "description": "Grid row of the section origin (editor layout)"
          }
        },
        "required": [
          "name",
          "rows",
          "cols",
          "tierName",
          "priceSatang"
        ]
      },
      "CreateSeatMapDto": {
        "type": "object",
        "properties": {
          "sections": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeatMapSectionDto"
            }
          }
        },
        "required": [
          "sections"
        ]
      },
      "OrderItemInputDto": {
        "type": "object",
        "properties": {
          "ticketTypeId": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "minimum": 1,
            "maximum": 20
          }
        },
        "required": [
          "ticketTypeId",
          "quantity"
        ]
      },
      "CreateOrderDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemInputDto"
            }
          },
          "seatIds": {
            "description": "Seat ids currently held by the caller",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "buyerEmail": {
            "type": "string",
            "example": "ada@example.com"
          },
          "buyerName": {
            "type": "string",
            "example": "Ada Lovelace"
          }
        },
        "required": [
          "buyerEmail",
          "buyerName"
        ]
      },
      "CreateRefundDto": {
        "type": "object",
        "properties": {
          "ticketIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "ticketIds"
        ]
      }
    }
  }
}
