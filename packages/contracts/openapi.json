  "info": {
    "title": "OpenSeat API",
    "description": "REST API for the OpenSeat ticketing platform",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "ada@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "maxLength": 72
          },
          "displayName": {
            "type": "string",
            "example": "Ada Lovelace"
          }
        },
        "required": [
          "email",
          "password",
          "displayName"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "ada@example.com"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "DemoLoginDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "buyer",
              "organizer"
            ]
          }
        },
        "required": [
          "role"
        ]
      },
      "CreateTicketTypeDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "General admission"
          },
          "quantity": {
            "type": "number",
            "minimum": 1,
            "maximum": 100000
          },
          "priceSatang": {
            "type": "number",
            "enum": [
              0
            ],
            "description": "Paid tickets arrive in a later milestone"
          },
          "maxPerOrder": {
            "type": "number",
            "minimum": 1,
            "maximum": 20,
            "default": 10
          }
        },
        "required": [
          "name",
          "quantity",
          "priceSatang"
        ]
      },
      "CreateEventDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Bangkok Indie Fest"
          },
          "description": {
            "type": "string",
            "default": ""
          },
          "venueName": {
            "type": "string",
            "example": "Voice Space, Bangkok"
          },
          "startsAt": {
            "type": "string",
            "example": "2026-09-01T12:00:00.000Z"
          },
          "endsAt": {
            "type": "string",
            "example": "2026-09-01T16:00:00.000Z"
          },
          "ticketTypes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateTicketTypeDto"
            }
          }
        },
        "required": [
          "title",
          "venueName",
          "startsAt",
          "ticketTypes"
        ]
      },
      "UpdateEventDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "venueName": {
            "type": "string"
          },
          "startsAt": {
            "type": "string"
          },
          "endsAt": {
            "type": "string"
          }
        }
      },
      "UpdateTicketTypeDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "minimum": 1,
            "maximum": 100000
          },
          "maxPerOrder": {
            "type": "number",
            "minimum": 1,
            "maximum": 20
          }
        }
      },
      "OrderItemInputDto": {
        "type": "object",
        "properties": {
          "ticketTypeId": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "minimum": 1,
            "maximum": 20
          }
        },
        "required": [
          "ticketTypeId",
          "quantity"
        ]
      },
      "CreateOrderDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemInputDto"
            }
          },
          "buyerEmail": {
            "type": "string",
            "example": "ada@example.com"
          },
          "buyerName": {
            "type": "string",
            "example": "Ada Lovelace"
          }
        },
        "required": [
          "items",
          "buyerEmail",
          "buyerName"
        ]
      }
    }
  }
}
