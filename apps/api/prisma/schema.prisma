generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  displayName  String   @map("display_name")
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  isDemo       Boolean  @default(false) @map("is_demo")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  events           Event[]
  orders           Order[]
  refreshTokens    RefreshToken[]
  refundsRequested Refund[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

enum EventStatus {
  draft
  published
}

model Event {
  id            String      @id @default(uuid())
  organizerId   String      @map("organizer_id")
  slug          String      @unique
  title         String
  description   String      @default("")
  venueName     String      @map("venue_name")
  startsAt      DateTime    @map("starts_at")
  endsAt        DateTime?   @map("ends_at")
  status        EventStatus @default(draft)
  coverImageUrl String?     @map("cover_image_url")
  isDemo        Boolean     @default(false) @map("is_demo")
  dropMode      Boolean     @default(false) @map("drop_mode")
  saleOpensAt   DateTime?   @map("sale_opens_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  organizer   User         @relation(fields: [organizerId], references: [id])
  ticketTypes TicketType[]
  orders      Order[]
  tickets     Ticket[]
  seatMap     SeatMap?
  seats       Seat[]
  holds       Hold[]

  @@index([organizerId])
  @@index([status, startsAt])
  @@map("events")
}

enum TicketTypeKind {
  ga
  seated
}

model TicketType {
  id          String         @id @default(uuid())
  eventId     String         @map("event_id")
  kind        TicketTypeKind @default(ga)
  name        String
  priceSatang Int            @default(0) @map("price_satang")
  quantity    Int
  remaining   Int
  maxPerOrder Int            @default(10) @map("max_per_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  tickets    Ticket[]
  seats      Seat[]

  @@index([eventId])
  @@map("ticket_types")
}

model SeatMap {
  id        String   @id @default(uuid())
  eventId   String   @unique @map("event_id")
  template  String
  meta      Json     @default("{}")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  seats Seat[]

  @@map("seat_maps")
}

model Seat {
  id           String @id @default(uuid())
  seatMapId    String @map("seat_map_id")
  eventId      String @map("event_id")
  ticketTypeId String @map("ticket_type_id")
  section      String
  rowLabel     String @map("row_label")
  number       Int
  x            Int
  y            Int

  seatMap    SeatMap    @relation(fields: [seatMapId], references: [id], onDelete: Cascade)
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  holds      Hold[]
  tickets    Ticket[]

  @@unique([seatMapId, section, rowLabel, number])
  @@index([eventId])
  @@map("seats")
}

model Hold {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  seatId    String   @map("seat_id")
  holderKey String   @map("holder_key")
  orderId   String?  @map("order_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  seat  Seat  @relation(fields: [seatId], references: [id], onDelete: Cascade)

  @@unique([eventId, seatId])
  @@index([expiresAt])
  @@index([holderKey])
  @@index([orderId])
  @@map("holds")
}

enum OrderStatus {
  pending
  awaiting_payment
  paid
  expired
  canceled
  partially_refunded
  refunded
}

enum RefundStatus {
  pending
  succeeded
  failed
}

model Order {
  id             String      @id @default(uuid())
  eventId        String      @map("event_id")
  buyerUserId    String?     @map("buyer_user_id")
  buyerEmail     String      @map("buyer_email")
  buyerName      String      @map("buyer_name")
  status         OrderStatus @default(pending)
  totalSatang    Int         @default(0) @map("total_satang")
  refundedSatang Int         @default(0) @map("refunded_satang")
  idempotencyKey String?     @map("idempotency_key")
  guestToken     String      @unique @map("guest_token")
  expiresAt      DateTime?   @map("expires_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  event   Event       @relation(fields: [eventId], references: [id])
  buyer   User?       @relation(fields: [buyerUserId], references: [id])
  items   OrderItem[]
  tickets Ticket[]
  payment Payment?
  refunds Refund[]

  @@unique([eventId, idempotencyKey])
  @@index([buyerUserId])
  @@index([buyerEmail])
  @@map("orders")
}

enum PaymentStatus {
  requires_action
  succeeded
  failed
}

model Payment {
  id               String        @id @default(uuid())
  orderId          String        @unique @map("order_id")
  providerIntentId String        @unique @map("provider_intent_id")
  checkoutUrl      String        @map("checkout_url")
  status           PaymentStatus @default(requires_action)
  amountSatang     Int           @map("amount_satang")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model WebhookEvent {
  id              String    @id @default(uuid())
  providerEventId String    @unique @map("provider_event_id")
  type            String
  receivedAt      DateTime  @default(now()) @map("received_at")
  processedAt     DateTime? @map("processed_at")

  @@map("webhook_events")
}

model OutboxEvent {
  id          String    @id @default(uuid())
  type        String
  payload     Json
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")

  @@index([processedAt, createdAt])
  @@map("outbox_events")
}

model OrderItem {
  id              String @id @default(uuid())
  orderId         String @map("order_id")
  ticketTypeId    String @map("ticket_type_id")
  quantity        Int
  unitPriceSatang Int    @map("unit_price_satang")

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

enum TicketStatus {
  issued
  checked_in
  void
}

model Ticket {
  id            String       @id @default(uuid())
  orderId       String       @map("order_id")
  eventId       String       @map("event_id")
  ticketTypeId  String       @map("ticket_type_id")
  seatId        String?      @map("seat_id")
  attendeeEmail String       @map("attendee_email")
  attendeeName  String       @map("attendee_name")
  qrToken       String       @unique @map("qr_token")
  status        TicketStatus @default(issued)
  refundId      String?      @map("refund_id")
  checkedInAt   DateTime?    @map("checked_in_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  order      Order      @relation(fields: [orderId], references: [id])
  event      Event      @relation(fields: [eventId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  seat       Seat?      @relation(fields: [seatId], references: [id])
  refund     Refund?    @relation(fields: [refundId], references: [id])

  @@index([eventId])
  @@index([orderId])
  @@index([refundId])
  @@map("tickets")
}

model Refund {
  id               String       @id @default(uuid())
  orderId          String       @map("order_id")
  providerRefundId String?      @map("provider_refund_id")
  amountSatang     Int          @map("amount_satang")
  status           RefundStatus @default(pending)
  idempotencyKey   String?      @map("idempotency_key")
  requestedById    String       @map("requested_by_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  settledAt        DateTime?    @map("settled_at")

  order       Order    @relation(fields: [orderId], references: [id])
  requestedBy User     @relation(fields: [requestedById], references: [id])
  tickets     Ticket[]

  @@unique([orderId, idempotencyKey])
  @@index([orderId])
  @@map("refunds")
}
