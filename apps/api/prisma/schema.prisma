generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  displayName  String   @map("display_name")
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  isDemo       Boolean  @default(false) @map("is_demo")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  events        Event[]
  orders        Order[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

enum EventStatus {
  draft
  published
}

model Event {
  id            String      @id @default(uuid())
  organizerId   String      @map("organizer_id")
  slug          String      @unique
  title         String
  description   String      @default("")
  venueName     String      @map("venue_name")
  startsAt      DateTime    @map("starts_at")
  endsAt        DateTime?   @map("ends_at")
  status        EventStatus @default(draft)
  coverImageUrl String?     @map("cover_image_url")
  isDemo        Boolean     @default(false) @map("is_demo")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  organizer   User         @relation(fields: [organizerId], references: [id])
  ticketTypes TicketType[]
  orders      Order[]
  tickets     Ticket[]

  @@index([organizerId])
  @@index([status, startsAt])
  @@map("events")
}

model TicketType {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  name        String
  priceSatang Int      @default(0) @map("price_satang")
  quantity    Int
  remaining   Int
  maxPerOrder Int      @default(10) @map("max_per_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  tickets    Ticket[]

  @@index([eventId])
  @@map("ticket_types")
}

enum OrderStatus {
  pending
  paid
  expired
  canceled
}

model Order {
  id             String      @id @default(uuid())
  eventId        String      @map("event_id")
  buyerUserId    String?     @map("buyer_user_id")
  buyerEmail     String      @map("buyer_email")
  buyerName      String      @map("buyer_name")
  status         OrderStatus @default(pending)
  totalSatang    Int         @default(0) @map("total_satang")
  idempotencyKey String?     @map("idempotency_key")
  guestToken     String      @unique @map("guest_token")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  event   Event       @relation(fields: [eventId], references: [id])
  buyer   User?       @relation(fields: [buyerUserId], references: [id])
  items   OrderItem[]
  tickets Ticket[]

  @@unique([eventId, idempotencyKey])
  @@index([buyerUserId])
  @@index([buyerEmail])
  @@map("orders")
}

model OrderItem {
  id              String @id @default(uuid())
  orderId         String @map("order_id")
  ticketTypeId    String @map("ticket_type_id")
  quantity        Int
  unitPriceSatang Int    @map("unit_price_satang")

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

enum TicketStatus {
  issued
  checked_in
  void
}

model Ticket {
  id            String       @id @default(uuid())
  orderId       String       @map("order_id")
  eventId       String       @map("event_id")
  ticketTypeId  String       @map("ticket_type_id")
  attendeeEmail String       @map("attendee_email")
  attendeeName  String       @map("attendee_name")
  qrToken       String       @unique @map("qr_token")
  status        TicketStatus @default(issued)
  checkedInAt   DateTime?    @map("checked_in_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  order      Order      @relation(fields: [orderId], references: [id])
  event      Event      @relation(fields: [eventId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([eventId])
  @@index([orderId])
  @@map("tickets")
}
